# =============================================
# SUARA CERDAS - Environment Variables
# Copy ke .env.local dan isi semua nilai
# JANGAN commit file .env.local ke git!
# =============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Suara Cerdas
JWT_SECRET=minimal-32-karakter-random-string-ganti-ini

# Gemini API (disimpan di sini untuk server-side saja)
GEMINI_API_KEY=AIzaSy...

# Email (opsional - untuk notifikasi)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@gmail.com
SMTP_PASS=app-password-gmail

# Admin
ADMIN_EMAIL=admin@suaracerdas.com
WHATSAPP_ADMIN=628xxxxxxxxx

# Bank Transfer
BANK_NAME=BCA
BANK_ACCOUNT=1234567890
BANK_HOLDER=Nama Pemilik Rekening
